  "item": [
    {
      "name": "CreateToken",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has token\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.token).to.be.a(\"string\");\r",
              "    pm.expect(json.token).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// Auto-save token ke environment\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"token\", json.token);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GetAllBookings",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an(\"array\");\r",
              "    pm.expect(json.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Each item has bookingid\", function () {\r",
              "    const json = pm.response.json();\r",
              "    json.forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"bookingid\");\r",
              "    });\r",
              "});\r",
              "\r",
              "// Auto-save salah satu booking_id untuk dipakai request berikutnya\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"booking_id\", json[0].bookingid);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/booking",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GetBookingById",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has required fields\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"firstname\");\r",
              "    pm.expect(json).to.have.property(\"lastname\");\r",
              "    pm.expect(json).to.have.property(\"totalprice\");\r",
              "    pm.expect(json).to.have.property(\"depositpaid\");\r",
              "    pm.expect(json).to.have.property(\"bookingdates\");\r",
              "    pm.expect(json).to.have.property(\"additionalneeds\");\r",
              "});\r",
              "\r",
              "pm.test(\"bookingdates has checkin and checkout\", function () {\r",
              "    const dates = pm.response.json().bookingdates;\r",
              "    pm.expect(dates).to.have.property(\"checkin\");\r",
              "    pm.expect(dates).to.have.property(\"checkout\");\r",
              "});\r",
              "\r",
              "pm.test(\"totalprice is a number\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.totalprice).to.be.a(\"number\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/booking/{{booking_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking",
            "{{booking_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "CreateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate random data biar tidak static\r",
              "const firstName = [\"James\", \"Sarah\", \"John\", \"Emily\", \"Michael\"];\r",
              "const lastName = [\"Brown\", \"Smith\", \"Johnson\", \"Williams\", \"Jones\"];\r",
              "const needs = [\"Breakfast\", \"Lunch\", \"Dinner\", \"Airport Shuttle\", \"None\"];\r",
              "\r",
              "const randomFirst = firstName[Math.floor(Math.random() * firstName.length)];\r",
              "const randomLast = lastName[Math.floor(Math.random() * lastName.length)];\r",
              "const randomPrice = Math.floor(Math.random() * 500) + 50;\r",
              "const randomNeed = needs[Math.floor(Math.random() * needs.length)];\r",
              "\r",
              "pm.environment.set(\"new_firstname\", randomFirst);\r",
              "pm.environment.set(\"new_lastname\", randomLast);\r",
              "pm.environment.set(\"new_price\", randomPrice);\r",
              "pm.environment.set(\"new_needs\", randomNeed);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"{{new_firstname}}\",\r\n    \"lastname\": \"{{new_lastname}}\",\r\n    \"totalprice\": {{new_price}},\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2025-01-01\",\r\n        \"checkout\": \"2025-01-07\"\r\n    },\r\n    \"additionalneeds\": \"{{new_needs}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "UpdateBooking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate updated data\r",
              "pm.environment.set(\"updated_firstname\", \"Updated\");\r",
              "pm.environment.set(\"updated_price\", 999);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Firstname updated correctly\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.firstname).to.eql(\"Updated\");\r",
              "});\r",
              "\r",
              "pm.test(\"Price updated correctly\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.totalprice).to.eql(999);\r",
              "});\r",
              "\r",
              "pm.test(\"depositpaid is false\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.depositpaid).to.be.false;\r",
              "});\r",
              "\r",
              "pm.test(\"Response has all required fields\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property(\"firstname\");\r",
              "    pm.expect(json).to.have.property(\"lastname\");\r",
              "    pm.expect(json).to.have.property(\"totalprice\");\r",
              "    pm.expect(json).to.have.property(\"bookingdates\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"{{updated_firstname}}\",\r\n    \"lastname\": \"{{new_lastname}}\",\r\n    \"totalprice\": {{updated_price}},\r\n    \"depositpaid\": false,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2025-02-01\",\r\n        \"checkout\": \"2025-02-10\"\r\n    },\r\n    \"additionalneeds\": \"Late checkout\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking/{{new_booking_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "booking",
            "{{new_booking_id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "DeleteBooking",
      "request": {
        "method": "GET",
        "header": []
      },
      "response": []
    }
  ]
